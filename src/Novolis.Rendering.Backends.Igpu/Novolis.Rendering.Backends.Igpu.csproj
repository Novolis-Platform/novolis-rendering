  <PropertyGroup>
    <RootNamespace>Novolis.Rendering.Backends.Igpu</RootNamespace>
    <AssemblyName>Novolis.Rendering.Backends.Igpu</AssemblyName>
    <PackageId>Novolis.Rendering.Backends.Igpu</PackageId>
    <IsPackable>true</IsPackable>
    <Description>ILGPU ray tracing backend (GPU compute with CPU fallback).</Description>
