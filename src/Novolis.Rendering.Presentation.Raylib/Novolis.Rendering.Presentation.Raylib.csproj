  <PropertyGroup>
    <RootNamespace>Novolis.Rendering.Presentation.Raylib</RootNamespace>
    <AssemblyName>Novolis.Rendering.Presentation.Raylib</AssemblyName>
    <PackageId>Novolis.Rendering.Presentation.Raylib</PackageId>
    <IsPackable>true</IsPackable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
